@page "/onboarding"
@rendermode InteractiveAuto
@inject ApiClient Api
@inject AuthStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Complete Your Profile - HireKarlo</PageTitle>

<div class="onboarding-page">
    <div class="onboarding-container">
        <!-- Progress Steps -->
        <div class="progress-steps">
            @for (int i = 1; i <= totalSteps; i++)
            {
                var step = i;
                <div class="step @(currentStep == step ? "active" : "") @(currentStep > step ? "completed" : "")">
                    <div class="step-number">
                        @if (currentStep > step)
                        {
                            <span>&#10003;</span>
                        }
                        else
                        {
                            <span>@step</span>
                        }
                    </div>
                    <span class="step-label">@GetStepLabel(step)</span>
                </div>
            }
        </div>

        <!-- Step Content -->
        <div class="step-content">
            @switch (currentStep)
            {
                case 1:
                    <!-- Welcome & Consent -->
                    <div class="step-panel welcome-step">
                        <div class="step-icon">&#127919;</div>
                        <h1>Welcome to <span class="gradient-text">HireKarlo</span>!</h1>
                        <p>Let's set up your profile to help you land your dream job faster.</p>

                        <div class="consent-section">
                            <h3>Before we begin, please review:</h3>

                            <label class="consent-item">
                                <input type="checkbox" @bind="consentNewsletter" />
                                <span class="checkmark"></span>
                                <div class="consent-text">
                                    <strong>&#9993; Weekly Job Alerts</strong>
                                    <p>Receive personalized job recommendations matching your profile</p>
                                </div>
                            </label>

                            <label class="consent-item">
                                <input type="checkbox" @bind="consentJobMatch" />
                                <span class="checkmark"></span>
                                <div class="consent-text">
                                    <strong>&#9733; Smart Job Matching</strong>
                                    <p>Allow us to scan job postings and notify you when we find 90%+ matches with your resume</p>
                                </div>
                            </label>

                            <label class="consent-item required-consent">
                                <input type="checkbox" @bind="consentDataProcessing" />
                                <span class="checkmark"></span>
                                <div class="consent-text">
                                    <strong>&#128274; Data Processing <span class="required-tag">*Required</span></strong>
                                    <p>I agree to the <a href="/privacy" target="_blank">Privacy Policy</a> and allow processing of my data to provide personalized recommendations</p>
                                </div>
                            </label>
                        </div>

                        @if (!consentDataProcessing)
                        {
                            <p class="consent-hint">Please check the Data Processing box above to continue</p>
                        }

                        <button class="btn btn-primary btn-large" @onclick="NextStep" 
                                disabled="@(!consentDataProcessing)">
                            @(consentDataProcessing ? "Get Started &#8594;" : "Accept Terms to Continue")
                        </button>
                    </div>
                    break;

                case 2:
                    <!-- Dream Companies -->
                    <div class="step-panel companies-step">
                        <div class="step-icon">&#127970;</div>
                        <h2>Your Dream Companies</h2>
                        <p>Select up to 10 companies you'd love to work for. We'll prioritize job alerts from these.</p>

                        <!-- Location Filter -->
                        <div class="location-filter">
                            <label>Your Location:</label>
                            <input type="text" @bind="userLocation" @bind:event="oninput" 
                                   placeholder="e.g., Bangalore, New York, London..." />
                        </div>

                        <!-- Category Tabs -->
                        <div class="company-category-tabs">
                            @foreach (var cat in companyCategories)
                            {
                                <button class="category-tab @(selectedCategory == cat.Key ? "active" : "")"
                                        @onclick="() => selectedCategory = cat.Key">
                                    @cat.Value
                                </button>
                            }
                        </div>

                        <div class="search-box">
                            <input type="text" @bind="companySearch" @bind:event="oninput" 
                                   @onkeydown="HandleCompanyKeyDown"
                                   placeholder="Search or type a company name..." />
                            @if (!string.IsNullOrEmpty(companySearch) && filteredCompanies.Any())
                            {
                                <div class="search-dropdown">
                                    @foreach (var company in filteredCompanies.Take(5))
                                    {
                                        <button class="dropdown-item" @onclick="() => AddCompany(company.Name)">
                                            <span class="company-logo">@company.Name[0]</span>
                                            <div class="company-info">
                                                <span class="company-name">@company.Name</span>
                                                <span class="company-meta">@company.Category - @company.Location</span>
                                            </div>
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <div class="selected-companies">
                            @foreach (var company in selectedCompanies)
                            {
                                <div class="company-chip">
                                    <span class="chip-logo">@company[0]</span>
                                    <span>@company</span>
                                    <button class="chip-remove" @onclick="() => RemoveCompany(company)">&#215;</button>
                                </div>
                            }
                        </div>

                        @if (selectedCompanies.Count >= 10)
                        {
                            <p class="limit-message">&#10003; Maximum 10 companies selected</p>
                        }
                        else
                        {
                            <p class="hint-message">@(10 - selectedCompanies.Count) more companies can be added</p>
                        }

                        <div class="suggested-companies">
                            <h4>@GetCategoryTitle()</h4>
                            <div class="company-grid">
                                @foreach (var company in GetCategoryCompanies().Where(c => !selectedCompanies.Contains(c.Name)).Take(12))
                                {
                                    <button class="company-btn" @onclick="() => AddCompany(company.Name)" 
                                            disabled="@(selectedCompanies.Count >= 10)">
                                        <span class="company-logo-small">@company.Name[0]</span>
                                        <div class="company-btn-info">
                                            <span>@company.Name</span>
                                            <small>@company.Location</small>
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                    break;

                case 3:
                    <!-- Skills & Experience -->
                    <div class="step-panel skills-step">
                        <div class="step-icon">&#128161;</div>
                        <h2>Your Skills &amp; Experience</h2>
                        <p>Help us understand your background so we can find the best matches.</p>

                        <div class="form-section">
                            <label>Years of Experience</label>
                            <div class="experience-options">
                                @foreach (var exp in experienceLevels)
                                {
                                    <button class="exp-btn @(selectedExperience == exp ? "active" : "")"
                                            @onclick="() => selectedExperience = exp">
                                        @exp
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="form-section">
                            <label>Your Skills</label>
                            <div class="skill-input">
                                <input type="text" @bind="skillSearch" @bind:event="oninput"
                                       @onkeydown="HandleSkillKeyDown"
                                       placeholder="Add a skill (e.g., C#, React, AWS)..." />
                            </div>

                            <div class="selected-skills">
                                @foreach (var skill in selectedSkills)
                                {
                                    <div class="skill-chip">
                                        @skill
                                        <button class="chip-remove" @onclick="() => RemoveSkill(skill)">&#215;</button>
                                    </div>
                                }
                            </div>

                            <div class="suggested-skills">
                                <span class="suggest-label">Suggested:</span>
                                @foreach (var skill in suggestedSkills.Where(s => !selectedSkills.Contains(s)).Take(8))
                                {
                                    <button class="skill-suggest-btn" @onclick="() => AddSkill(skill)">+ @skill</button>
                                }
                            </div>
                        </div>

                        <div class="form-section">
                            <label>Target Role</label>
                            <input type="text" @bind="targetRole" placeholder="e.g., Senior Software Engineer, Product Manager..." />
                        </div>

                        <div class="form-section">
                            <label>Preferred Locations</label>
                            <div class="location-options">
                                <label class="location-check">
                                    <input type="checkbox" @bind="preferRemote" />
                                    <span>&#127968; Remote</span>
                                </label>
                                <input type="text" @bind="preferredLocation" placeholder="City, State or Country..." />
                            </div>
                        </div>
                    </div>
                    break;

                case 4:
                    <!-- Resume Upload -->
                    <div class="step-panel resume-step">
                        <div class="step-icon">&#128196;</div>
                        <h2>Upload Your Resume</h2>
                        <p>We'll analyze your resume before every job application to give you an ATS match score.</p>

                        <div class="upload-area @(isDragging ? "dragging" : "") @(resumeUploaded ? "uploaded" : "")"
                             @ondragenter="HandleDragEnter" @ondragleave="HandleDragLeave" @ondrop="HandleDrop">
                            @if (resumeUploaded)
                            {
                                <div class="upload-success">
                                    <span class="success-icon">&#10004;</span>
                                    <h3>Resume Uploaded!</h3>
                                    <p>@resumeFileName</p>
                                    <button class="btn btn-ghost" @onclick="RemoveResume">Remove &amp; Upload Another</button>
                                </div>
                            }
                            else if (isUploading)
                            {
                                <div class="uploading">
                                    <div class="upload-spinner"></div>
                                    <p>Uploading...</p>
                                </div>
                            }
                            else
                            {
                                <div class="upload-prompt">
                                    <span class="upload-icon">&#128193;</span>
                                    <h3>Drag &amp; Drop your resume here</h3>
                                    <p>or</p>
                                    <label class="btn btn-secondary upload-btn">
                                        Browse Files
                                        <InputFile OnChange="HandleFileSelected" accept=".pdf,.doc,.docx" style="display:none" />
                                    </label>
                                    <p class="file-hint">PDF, DOC, or DOCX (Max 5MB)</p>
                                </div>
                            }
                        </div>

                        <div class="ats-info">
                            <h4>&#127919; How ATS Matching Works</h4>
                            <ul>
                                <li>Before each job application, we scan both your resume and the job description</li>
                                <li>If your match score is 90%+, we notify you immediately</li>
                                <li>Get keyword suggestions to improve your resume for specific roles</li>
                            </ul>
                        </div>
                    </div>
                    break;

                case 5:
                    <!-- Completion -->
                    <div class="step-panel complete-step">
                        <div class="step-icon">&#127881;</div>
                        <h2>You're All Set!</h2>
                        <p>Your profile is ready. Here's what happens next:</p>

                        <div class="summary-cards">
                            <div class="summary-card">
                                <span class="card-icon">&#127970;</span>
                                <h4>@selectedCompanies.Count Dream Companies</h4>
                                <p>We'll prioritize jobs from these companies</p>
                            </div>
                            <div class="summary-card">
                                <span class="card-icon">&#128161;</span>
                                <h4>@selectedSkills.Count Skills Added</h4>
                                <p>Used for smart job matching</p>
                            </div>
                            @if (resumeUploaded)
                            {
                                <div class="summary-card">
                                    <span class="card-icon">&#128196;</span>
                                    <h4>Resume Ready</h4>
                                    <p>ATS analysis enabled</p>
                                </div>
                            }
                        </div>

                        <div class="next-actions">
                            <button class="btn btn-primary btn-large" @onclick="CompleteOnboarding">
                                &#128640; Start Exploring Jobs
                            </button>
                            <button class="btn btn-secondary" @onclick="GoToResumes">
                                &#128196; Upload More Resumes
                            </button>
                        </div>
                    </div>
                    break;
            }
        </div>

        <!-- Navigation Buttons -->
        @if (currentStep > 1 && currentStep < 5)
        {
            <div class="step-navigation">
                <button class="btn btn-ghost" @onclick="PreviousStep">&#8592; Back</button>
                <button class="btn btn-primary" @onclick="NextStep" disabled="@(!CanProceed())">
                    @(currentStep == 4 ? "Complete Setup &#8594;" : "Continue &#8594;")
                </button>
            </div>
        }

        @if (currentStep > 1 && currentStep < 5)
        {
            <button class="skip-btn" @onclick="SkipToEnd">Skip for now</button>
        }
    </div>
</div>

@code {
    private int currentStep = 1;
    private const int totalSteps = 5;

    // Step 1: Consent
    private bool consentNewsletter = true;
    private bool consentJobMatch = true;
    private bool consentDataProcessing = false;

    // Step 2: Companies
    private string companySearch = "";
    private string userLocation = "";
    private string selectedCategory = "faang";
    private List<string> selectedCompanies = new();

    private Dictionary<string, string> companyCategories = new()
    {
        { "faang", "FAANG+" },
        { "fortune500", "Fortune 500" },
        { "productBased", "Top Product" },
        { "startups", "Hot Startups" },
        { "indian", "Indian IT" },
        { "remote", "Remote First" }
    };

    private List<CompanyInfo> allCompanies = new()
    {
        // FAANG+
        new("Google", "FAANG+", "Global"),
        new("Microsoft", "FAANG+", "Global"),
        new("Amazon", "FAANG+", "Global"),
        new("Apple", "FAANG+", "Global"),
        new("Meta", "FAANG+", "Global"),
        new("Netflix", "FAANG+", "Global"),
        new("Nvidia", "FAANG+", "Global"),
        new("Tesla", "FAANG+", "Global"),

        // Fortune 500
        new("JPMorgan Chase", "Fortune 500", "New York"),
        new("Goldman Sachs", "Fortune 500", "New York"),
        new("Walmart", "Fortune 500", "Arkansas"),
        new("Johnson & Johnson", "Fortune 500", "New Jersey"),
        new("Procter & Gamble", "Fortune 500", "Ohio"),
        new("Bank of America", "Fortune 500", "Charlotte"),
        new("Citigroup", "Fortune 500", "New York"),
        new("Wells Fargo", "Fortune 500", "San Francisco"),

        // Top Product Companies
        new("Stripe", "Top Product", "San Francisco"),
        new("Airbnb", "Top Product", "San Francisco"),
        new("Uber", "Top Product", "San Francisco"),
        new("Spotify", "Top Product", "Stockholm"),
        new("Salesforce", "Top Product", "San Francisco"),
        new("Adobe", "Top Product", "San Jose"),
        new("Atlassian", "Top Product", "Sydney"),
        new("Slack", "Top Product", "San Francisco"),
        new("Dropbox", "Top Product", "San Francisco"),
        new("Zoom", "Top Product", "San Jose"),
        new("Shopify", "Top Product", "Ottawa"),
        new("Twilio", "Top Product", "San Francisco"),

        // Hot Startups
        new("OpenAI", "Startup", "San Francisco"),
        new("Anthropic", "Startup", "San Francisco"),
        new("Figma", "Startup", "San Francisco"),
        new("Notion", "Startup", "San Francisco"),
        new("Vercel", "Startup", "San Francisco"),
        new("Linear", "Startup", "San Francisco"),
        new("Retool", "Startup", "San Francisco"),
        new("Rippling", "Startup", "San Francisco"),
        new("Ramp", "Startup", "New York"),
        new("Faire", "Startup", "San Francisco"),
        new("Scale AI", "Startup", "San Francisco"),
        new("Databricks", "Startup", "San Francisco"),

        // Indian IT & Product
        new("Flipkart", "Indian", "Bangalore"),
        new("Swiggy", "Indian", "Bangalore"),
        new("Zomato", "Indian", "Gurgaon"),
        new("Razorpay", "Indian", "Bangalore"),
        new("Zerodha", "Indian", "Bangalore"),
        new("PhonePe", "Indian", "Bangalore"),
        new("Paytm", "Indian", "Noida"),
        new("Ola", "Indian", "Bangalore"),
        new("CRED", "Indian", "Bangalore"),
        new("Meesho", "Indian", "Bangalore"),
        new("Dream11", "Indian", "Mumbai"),
        new("upGrad", "Indian", "Mumbai"),
        new("TCS", "Indian", "Mumbai"),
        new("Infosys", "Indian", "Bangalore"),
        new("Wipro", "Indian", "Bangalore"),
        new("HCL Tech", "Indian", "Noida"),

        // Remote First
        new("GitLab", "Remote First", "Remote"),
        new("Zapier", "Remote First", "Remote"),
        new("Automattic", "Remote First", "Remote"),
        new("Buffer", "Remote First", "Remote"),
        new("Doist", "Remote First", "Remote"),
        new("Toptal", "Remote First", "Remote"),
        new("InVision", "Remote First", "Remote"),
        new("Canonical", "Remote First", "Remote")
    };

    private List<CompanyInfo> filteredCompanies => string.IsNullOrEmpty(companySearch)
        ? new List<CompanyInfo>()
        : allCompanies.Where(c => c.Name.Contains(companySearch, StringComparison.OrdinalIgnoreCase) 
            && !selectedCompanies.Contains(c.Name)).ToList();

    private List<CompanyInfo> GetCategoryCompanies()
    {
        var categoryMap = new Dictionary<string, string>
        {
            { "faang", "FAANG+" },
            { "fortune500", "Fortune 500" },
            { "productBased", "Top Product" },
            { "startups", "Startup" },
            { "indian", "Indian" },
            { "remote", "Remote First" }
        };

        var category = categoryMap.GetValueOrDefault(selectedCategory, "FAANG+");
        var companies = allCompanies.Where(c => c.Category == category);

        if (!string.IsNullOrEmpty(userLocation))
        {
            var locationMatches = companies.Where(c => 
                c.Location.Contains(userLocation, StringComparison.OrdinalIgnoreCase) ||
                c.Location == "Global" || c.Location == "Remote");
            if (locationMatches.Any())
                return locationMatches.ToList();
        }

        return companies.ToList();
    }

    private string GetCategoryTitle() => selectedCategory switch
    {
        "faang" => "FAANG+ Companies",
        "fortune500" => "Fortune 500 Companies",
        "productBased" => "Top Product Companies",
        "startups" => "Hot Startups",
        "indian" => "Indian Tech Companies",
        "remote" => "Remote-First Companies",
        _ => "Popular Companies"
    };

    // Step 3: Skills
    private string skillSearch = "";
    private List<string> selectedSkills = new();
    private string selectedExperience = "";
    private string targetRole = "";
    private string preferredLocation = "";
    private bool preferRemote = true;
    private readonly string[] experienceLevels = { "0-1 years", "1-3 years", "3-5 years", "5-10 years", "10+ years" };
    private readonly List<string> suggestedSkills = new()
    {
        "JavaScript", "TypeScript", "React", "Node.js", "Python", "C#", ".NET", "Java",
        "AWS", "Azure", "Docker", "Kubernetes", "SQL", "MongoDB", "GraphQL", "REST APIs",
        "Git", "CI/CD", "Agile", "Scrum", "Machine Learning", "Data Science"
    };

    // Step 4: Resume
    private bool resumeUploaded = false;
    private string resumeFileName = "";
    private bool isUploading = false;
    private bool isDragging = false;

    private string GetStepLabel(int step) => step switch
    {
        1 => "Welcome",
        2 => "Companies",
        3 => "Skills",
        4 => "Resume",
        5 => "Complete",
        _ => ""
    };

    private void NextStep()
    {
        if (currentStep < totalSteps)
            currentStep++;
    }

    private void PreviousStep()
    {
        if (currentStep > 1)
            currentStep--;
    }

    private void SkipToEnd() => currentStep = 5;

    private bool CanProceed() => currentStep switch
    {
        1 => consentDataProcessing,
        2 => true, // Companies are optional
        3 => true, // Skills are optional
        4 => true, // Resume is optional
        _ => true
    };

    // Company methods
    private void HandleCompanyKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(companySearch) && selectedCompanies.Count < 10)
        {
            AddCompany(companySearch);
        }
    }

    private void AddCompany(string company)
    {
        if (selectedCompanies.Count < 10 && !selectedCompanies.Contains(company))
        {
            selectedCompanies.Add(company);
            companySearch = "";
        }
    }

    private void RemoveCompany(string company)
    {
        selectedCompanies.Remove(company);
    }

    // Skill methods
    private void HandleSkillKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(skillSearch))
        {
            AddSkill(skillSearch);
        }
    }

    private void AddSkill(string skill)
    {
        if (!selectedSkills.Contains(skill))
        {
            selectedSkills.Add(skill);
            skillSearch = "";
        }
    }

    private void RemoveSkill(string skill)
    {
        selectedSkills.Remove(skill);
    }

    // File upload methods
    private void HandleDragEnter() => isDragging = true;
    private void HandleDragLeave() => isDragging = false;
    private void HandleDrop() => isDragging = false;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && file.Size <= 5 * 1024 * 1024) // 5MB limit
        {
            isUploading = true;
            StateHasChanged();

            // Simulate upload delay
            await Task.Delay(1500);

            resumeFileName = file.Name;
            resumeUploaded = true;
            isUploading = false;
        }
    }

    private void RemoveResume()
    {
        resumeUploaded = false;
        resumeFileName = "";
    }

    private async Task CompleteOnboarding()
    {
        // Save user preferences to API
        try
        {
            // TODO: Call API to save onboarding data
            // await Api.SaveOnboardingDataAsync(new OnboardingData { ... });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving onboarding data: {ex.Message}");
        }

        Navigation.NavigateTo("/jobs");
    }

    private void GoToResumes()
    {
        Navigation.NavigateTo("/resumes");
    }

    // Helper class
    private record CompanyInfo(string Name, string Category, string Location);
}

<style>
    .onboarding-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .onboarding-container {
        width: 100%;
        max-width: 700px;
    }

    .progress-steps {
        display: flex;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding: 0 1rem;
    }

    .step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        opacity: 0.5;
        transition: all 0.3s;
    }

    .step.active, .step.completed {
        opacity: 1;
    }

    .step-number {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--bg-secondary);
        border: 2px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        transition: all 0.3s;
    }

    .step.active .step-number {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .step.completed .step-number {
        background: var(--success);
        border-color: var(--success);
        color: white;
    }

    .step-label {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .step.active .step-label {
        color: var(--text-primary);
    }

    /* Step Content */
    .step-content {
        background: linear-gradient(145deg, rgba(30, 30, 60, 0.6), rgba(20, 20, 40, 0.8));
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2.5rem;
        margin-bottom: 1.5rem;
    }

    .step-panel {
        text-align: center;
    }

    .step-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .step-panel h1, .step-panel h2 {
        color: white;
        margin-bottom: 0.5rem;
    }

    .step-panel > p {
        color: var(--text-secondary);
        margin-bottom: 2rem;
    }

    /* Consent Section */
    .consent-section {
        text-align: left;
        margin: 2rem 0;
    }

    .consent-section h3 {
        margin-bottom: 1rem;
        font-size: 1rem;
    }

    .consent-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        margin-bottom: 0.75rem;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .consent-item:hover {
        background: rgba(255, 255, 255, 0.05);
    }

    .consent-item.required-consent {
        border-color: rgba(239, 68, 68, 0.5);
        background: rgba(239, 68, 68, 0.05);
    }

    .consent-item.required-consent:has(input:checked) {
        border-color: var(--success);
        background: rgba(16, 185, 129, 0.1);
    }

    .consent-item input {
        margin-top: 0.25rem;
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .consent-text strong {
        display: block;
        margin-bottom: 0.25rem;
    }

    .consent-text p {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin: 0;
    }

