@page "/resumes"
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Resumes - HireKarlo</PageTitle>

<div class="resumes-page">
    <div class="page-header">
        <div>
            <h1>📄 My Resumes</h1>
            <p>Upload, manage, and optimize your resumes for ATS systems</p>
        </div>
        <button class="btn btn-primary" @onclick="OpenUploadModal">
            <span>+</span> Upload Resume
        </button>
    </div>

    <div class="content-grid">
        <!-- Resume List -->
        <div class="resumes-list">
            @if (resumes.Any())
            {
                @foreach (var resume in resumes)
                {
                    <div class="resume-card @(selectedResume?.Id == resume.Id ? "selected" : "")" 
                         @onclick="() => SelectResume(resume)">
                        <div class="resume-icon">📄</div>
                        <div class="resume-info">
                            <span class="resume-name">@resume.FileName</span>
                            <span class="resume-date">Uploaded @resume.UploadedAt.ToString("MMM dd, yyyy")</span>
                            @if (resume.IsMaster)
                            {
                                <span class="badge master">Master</span>
                            }
                        </div>
                        <div class="resume-actions">
                            <button class="icon-btn" title="Download">⬇️</button>
                            <button class="icon-btn" title="Delete" @onclick:stopPropagation @onclick="() => DeleteResume(resume.Id)">🗑️</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <span class="empty-icon">📄</span>
                    <h3>No resumes yet</h3>
                    <p>Upload your first resume to get started</p>
                    <button class="btn btn-primary" @onclick="OpenUploadModal">Upload Resume</button>
                </div>
            }
        </div>

        <!-- ATS Checker Panel -->
        <div class="ats-panel">
            <div class="panel-header">
                <h3>🎯 ATS Score Checker</h3>
            </div>

            @if (selectedResume != null)
            {
                <div class="panel-body">
                    <div class="selected-resume">
                        <span>Selected: <strong>@selectedResume.FileName</strong></span>
                    </div>

                    <div class="form-group">
                        <label>Paste Job Description</label>
                        <textarea @bind="jobDescription" rows="8" placeholder="Paste the job description here to check ATS compatibility..."></textarea>
                    </div>

                    <button class="btn btn-primary full-width" @onclick="CheckAtsScore" disabled="@(isChecking || string.IsNullOrWhiteSpace(jobDescription))">
                        @if (isChecking)
                        {
                            <span>Analyzing...</span>
                        }
                        else
                        {
                            <span>Check ATS Score</span>
                        }
                    </button>

                    @if (atsResult != null)
                    {
                        <div class="ats-results">
                            <div class="score-circle @GetScoreClass(atsResult.Score)">
                                <span class="score-value">@atsResult.Score</span>
                                <span class="score-label">ATS Score</span>
                            </div>

                            <div class="keywords-section">
                                <h4>✅ Matching Keywords</h4>
                                <div class="keyword-tags">
                                    @foreach (var keyword in atsResult.MatchingKeywords.Take(10))
                                    {
                                        <span class="tag success">@keyword</span>
                                    }
                                </div>
                            </div>

                            <div class="keywords-section">
                                <h4>❌ Missing Keywords</h4>
                                <div class="keyword-tags">
                                    @foreach (var keyword in atsResult.MissingKeywords.Take(10))
                                    {
                                        <span class="tag warning">@keyword</span>
                                    }
                                </div>
                            </div>

                            <div class="suggestions-section">
                                <h4>💡 Suggestions</h4>
                                <ul>
                                    @foreach (var suggestion in atsResult.Suggestions)
                                    {
                                        <li>@suggestion</li>
                                    }
                                </ul>
                            </div>

                            <button class="btn btn-secondary full-width" @onclick="GenerateTailoredResume">
                                🚀 Generate Tailored Resume
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="panel-body empty">
                    <p>Select a resume to check its ATS compatibility</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Upload Modal -->
@if (showUploadModal)
{
    <div class="modal-overlay" @onclick="CloseUploadModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Upload Resume</h3>
                <button class="close-btn" @onclick="CloseUploadModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="upload-zone @(isDragging ? "dragging" : "")"
                     @ondragenter="HandleDragEnter"
                     @ondragleave="HandleDragLeave"
                     @ondragover:preventDefault>
                    <InputFile OnChange="HandleFileSelected" accept=".pdf,.docx,.doc,.txt" />
                    <span class="upload-icon">📄</span>
                    <p>Drag & drop your resume here or <span class="link">browse</span></p>
                    <span class="upload-hint">Supports PDF, DOCX, DOC, TXT (Max 5MB)</span>
                </div>

                @if (uploadFile != null)
                {
                    <div class="selected-file">
                        <span>📄 @uploadFile.Name</span>
                        <button @onclick="ClearFile">✕</button>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseUploadModal">Cancel</button>
                <button class="btn btn-primary" @onclick="UploadResume" disabled="@(uploadFile == null || isUploading)">
                    @(isUploading ? "Uploading..." : "Upload")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .resumes-page { max-width: 1400px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .page-header h1 { margin-bottom: 0.25rem; }
    .page-header p { color: var(--text-secondary); }

    .content-grid { display: grid; grid-template-columns: 1fr 400px; gap: 2rem; }

    .resumes-list { display: flex; flex-direction: column; gap: 1rem; }
    .resume-card { background: var(--bg-card); padding: 1rem 1.25rem; border-radius: 12px; border: 1px solid var(--border); display: flex; align-items: center; gap: 1rem; cursor: pointer; transition: all 0.2s; }
    .resume-card:hover { border-color: var(--primary); }
    .resume-card.selected { border-color: var(--primary); background: rgba(99, 102, 241, 0.1); }
    .resume-icon { font-size: 2rem; }
    .resume-info { flex: 1; display: flex; flex-direction: column; }
    .resume-name { font-weight: 600; }
    .resume-date { color: var(--text-secondary); font-size: 0.875rem; }
    .badge { padding: 0.125rem 0.5rem; border-radius: 4px; font-size: 0.75rem; margin-top: 0.25rem; width: fit-content; }
    .badge.master { background: var(--primary); color: white; }
    .resume-actions { display: flex; gap: 0.5rem; }
    .icon-btn { background: none; border: none; cursor: pointer; font-size: 1rem; padding: 0.5rem; border-radius: 6px; transition: background 0.2s; }
    .icon-btn:hover { background: var(--bg-hover); }

    .ats-panel { background: var(--bg-card); border-radius: 12px; border: 1px solid var(--border); height: fit-content; position: sticky; top: 80px; }
    .panel-header { padding: 1rem 1.25rem; border-bottom: 1px solid var(--border); }
    .panel-body { padding: 1.25rem; }
    .panel-body.empty { text-align: center; color: var(--text-secondary); padding: 3rem; }

    .selected-resume { background: var(--bg-hover); padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1rem; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 500; }
    .form-group textarea { width: 100%; padding: 0.75rem; background: var(--bg-dark); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); resize: vertical; }
    .form-group textarea:focus { outline: none; border-color: var(--primary); }

    .full-width { width: 100%; }

    .ats-results { margin-top: 1.5rem; }
    .score-circle { width: 120px; height: 120px; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 0 auto 1.5rem; }
    .score-circle.high { background: rgba(34, 197, 94, 0.2); border: 3px solid #22c55e; }
    .score-circle.medium { background: rgba(245, 158, 11, 0.2); border: 3px solid #f59e0b; }
    .score-circle.low { background: rgba(239, 68, 68, 0.2); border: 3px solid #ef4444; }
    .score-value { font-size: 2rem; font-weight: 700; }
    .score-label { font-size: 0.875rem; color: var(--text-secondary); }

    .keywords-section { margin-bottom: 1rem; }
    .keywords-section h4 { margin-bottom: 0.5rem; font-size: 0.9rem; }
    .keyword-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .tag { padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.8rem; }
    .tag.success { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
    .tag.warning { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }

    .suggestions-section { margin-bottom: 1.5rem; }
    .suggestions-section h4 { margin-bottom: 0.5rem; font-size: 0.9rem; }
    .suggestions-section ul { padding-left: 1.25rem; color: var(--text-secondary); }
    .suggestions-section li { margin-bottom: 0.5rem; }

    /* Modal */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.7); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal { background: var(--bg-card); border-radius: 16px; width: 500px; max-width: 90vw; }
    .modal-header { padding: 1.25rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
    .close-btn { background: none; border: none; color: var(--text-secondary); font-size: 1.25rem; cursor: pointer; }
    .modal-body { padding: 1.5rem; }
    .modal-footer { padding: 1rem 1.5rem; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 0.75rem; }

    .upload-zone { border: 2px dashed var(--border); border-radius: 12px; padding: 3rem; text-align: center; position: relative; transition: all 0.2s; }
    .upload-zone:hover, .upload-zone.dragging { border-color: var(--primary); background: rgba(99, 102, 241, 0.05); }
    .upload-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
    .upload-icon { font-size: 3rem; display: block; margin-bottom: 1rem; }
    .upload-zone .link { color: var(--primary); }
    .upload-hint { display: block; margin-top: 0.5rem; color: var(--text-secondary); font-size: 0.875rem; }

    .selected-file { display: flex; justify-content: space-between; align-items: center; background: var(--bg-hover); padding: 0.75rem 1rem; border-radius: 8px; margin-top: 1rem; }
    .selected-file button { background: none; border: none; color: var(--text-secondary); cursor: pointer; }

    .empty-state { text-align: center; padding: 4rem 2rem; background: var(--bg-card); border-radius: 12px; border: 1px dashed var(--border); }
    .empty-icon { font-size: 4rem; display: block; margin-bottom: 1rem; }
    .empty-state h3 { margin-bottom: 0.5rem; }
    .empty-state p { color: var(--text-secondary); margin-bottom: 1.5rem; }

    .btn { padding: 0.75rem 1.5rem; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; }
    .btn-primary { background: var(--primary); color: white; }
    .btn-primary:hover:not(:disabled) { background: var(--primary-dark); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-secondary { background: var(--bg-hover); color: var(--text-primary); }

    @@media (max-width: 1024px) {
        .content-grid { grid-template-columns: 1fr; }
        .ats-panel { position: static; }
    }
</style>

@code {
    private List<ResumeDto> resumes = new();
    private ResumeDto? selectedResume;
    private string jobDescription = "";
    private AtsScoreResult? atsResult;
    private bool isChecking;
    private bool showUploadModal;
    private bool isDragging;
    private IBrowserFile? uploadFile;
    private bool isUploading;

    protected override async Task OnInitializedAsync()
    {
        resumes = await Api.GetResumesAsync();
    }

    private void SelectResume(ResumeDto resume)
    {
        selectedResume = resume;
        atsResult = null;
    }

    private async Task CheckAtsScore()
    {
        if (selectedResume == null || string.IsNullOrWhiteSpace(jobDescription)) return;

        isChecking = true;
        atsResult = await Api.GetAtsScoreAsync(selectedResume.Id, jobDescription);
        isChecking = false;
    }

    private string GetScoreClass(int score) => score >= 80 ? "high" : score >= 60 ? "medium" : "low";

    private void OpenUploadModal() => showUploadModal = true;
    private void CloseUploadModal() { showUploadModal = false; uploadFile = null; }
    private void HandleDragEnter() => isDragging = true;
    private void HandleDragLeave() => isDragging = false;
    private void HandleFileSelected(InputFileChangeEventArgs e) => uploadFile = e.File;
    private void ClearFile() => uploadFile = null;

    private async Task UploadResume()
    {
        if (uploadFile == null) return;

        isUploading = true;
        var content = new MultipartFormDataContent();
        var stream = uploadFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        content.Add(new StreamContent(stream), "file", uploadFile.Name);

        var result = await Api.UploadResumeAsync(content);
        if (result != null)
        {
            resumes.Insert(0, result);
            CloseUploadModal();
        }
        isUploading = false;
    }

    private async Task DeleteResume(Guid id)
    {
        // TODO: Call API to delete
        resumes.RemoveAll(r => r.Id == id);
        if (selectedResume?.Id == id) selectedResume = null;
    }

    private async Task GenerateTailoredResume()
    {
        // TODO: Implement tailored resume generation
    }
}
