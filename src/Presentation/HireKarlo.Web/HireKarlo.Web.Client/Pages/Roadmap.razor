        justify-content: center;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-secondary);
        z-index: 1;
    }

    .milestone.active .milestone-marker {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    .milestone.completed .milestone-marker {
        background: var(--success);
        border-color: var(--success);
    }

    .milestone-info {
        flex: 1;
    }

    .milestone-meta {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .month-badge {
        padding: 0.25rem 0.5rem;
        background: rgba(139, 92, 246, 0.2);
        border-radius: 4px;
        font-size: 0.75rem;
        color: var(--primary);
    }

    .progress-badge {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .milestone-info h3 {
        color: white;
        margin: 0 0 0.25rem;
        font-size: 1.1rem;
    }

    .milestone-info p {
        color: var(--text-secondary);
        margin: 0;
        font-size: 0.9rem;
    }

    .expand-icon {
        color: var(--text-muted);
    }

    .milestone-content {
        margin-top: 0.5rem;
        padding: 1rem;
