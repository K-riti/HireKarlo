        color: var(--secondary);
    }

    /* Schedule Section */
    .schedule-section {
        margin-top: 2rem;
        padding: 1.5rem;
        background: linear-gradient(145deg, rgba(30, 30, 60, 0.6), rgba(20, 20, 40, 0.8));
        border: 1px solid var(--border);
        border-radius: 16px;
    }

    .schedule-section h2 {
        color: white;
        margin: 0 0 1rem;
    }

    .weekly-task {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 10px;
        margin-bottom: 0.75rem;
    }

    .day-badge {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        color: white;
    }

    .task-details {
        flex: 1;
    }

    .task-details h4 {
        color: white;
        margin: 0 0 0.25rem;
        font-size: 0.95rem;
    }

    .task-details p {
        color: var(--text-muted);
        margin: 0;
        font-size: 0.8rem;
