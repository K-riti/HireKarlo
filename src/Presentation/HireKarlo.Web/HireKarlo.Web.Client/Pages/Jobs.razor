@page "/jobs"
@rendermode InteractiveAuto
@inject ApiClient Api
@inject NavigationManager Navigation

<PageTitle>🎯 Quest Board - HireKarlo</PageTitle>

<!-- ATS Score Modal -->
@if (showAtsModal)
{
    <div class="modal-overlay" @onclick="CloseAtsModal">
        <div class="ats-modal" @onclick:stopPropagation="true">
            <button class="modal-close" @onclick="CloseAtsModal">×</button>

            @if (isAnalyzing)
            {
                <div class="analyzing-state">
                    <div class="analyzing-animation">
                        <div class="scan-line"></div>
                        📄
                    </div>
                    <h3>Analyzing Your Resume...</h3>
                    <p>Comparing your skills with job requirements</p>
                    <div class="progress-bar">
                        <div class="progress-fill animate"></div>
                    </div>
                </div>
            }
            else if (atsResult != null)
            {
                <div class="ats-result">
                    <div class="result-header">
                        <div class="score-circle @GetAtsScoreClass(atsResult.Score)">
                            <span class="score-value">@atsResult.Score%</span>
                            <span class="score-label">ATS Match</span>
                        </div>
                        <div class="result-info">
                            <h3>@GetAtsScoreTitle(atsResult.Score)</h3>
                            <p>@GetAtsScoreDescription(atsResult.Score)</p>
                        </div>
                    </div>

                    <div class="result-sections">
                        <div class="result-section matched">
                            <h4>✅ Matching Skills (@atsResult.MatchedSkills.Count)</h4>
                            <div class="skill-tags">
                                @foreach (var skill in atsResult.MatchedSkills)
                                {
                                    <span class="skill-tag matched">@skill</span>
                                }
                            </div>
                        </div>

                        @if (atsResult.MissingSkills.Any())
                        {
                            <div class="result-section missing">
                                <h4>⚠️ Missing Keywords (@atsResult.MissingSkills.Count)</h4>
                                <div class="skill-tags">
                                    @foreach (var skill in atsResult.MissingSkills)
                                    {
                                        <span class="skill-tag missing">@skill</span>
                                    }
                                </div>
                            </div>
                        }

                        @if (atsResult.Suggestions.Any())
                        {
                            <div class="result-section suggestions">
                                <h4>💡 Suggestions</h4>
                                <ul>
                                    @foreach (var suggestion in atsResult.Suggestions)
                                    {
                                        <li>@suggestion</li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>

                    <div class="modal-actions">
                        @if (atsResult.Score >= 70)
                        {
                            <button class="btn btn-primary" @onclick="ProceedToApply">
                                🚀 Apply Now
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary" @onclick="GoToTailorResume">
                                ✏️ Improve Resume First
                            </button>
                            <button class="btn btn-ghost" @onclick="ProceedToApply">
                                Apply Anyway
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="no-resume-state">
                    <div class="no-resume-icon">📄❓</div>
                    <h3>No Resume Found</h3>
                    <p>Upload your resume to get an ATS match score before applying</p>
                    <button class="btn btn-primary" @onclick="GoToUploadResume">
                        📤 Upload Resume
                    </button>
                    <button class="btn btn-ghost" @onclick="ProceedToApply">
                        Skip & Apply Anyway
                    </button>
                </div>
            }
        </div>
    </div>
}

<div class="jobs-page">
    <!-- 🏰 Quest Board Header -->
    <div class="quest-header">
        <div class="header-content">
            <div class="header-badge">🗺️ Quest Board</div>
            <h1>Find Your Next <span class="gradient-text">Adventure</span></h1>
            <p>@jobs.Count quests available • Level up your career!</p>
        </div>
    </div>

    <!-- 🔍 Enhanced Search Section -->
    <div class="search-section">
        <div class="search-container">
            <div class="search-main">
                <div class="search-input-group">
                    <span class="input-icon">🔍</span>
                    <input type="text" @bind="searchQuery" @bind:event="oninput" 
                           @onkeydown="HandleKeyDown"
                           placeholder="Search jobs, skills, or companies..." />
                </div>
                <div class="search-input-group">
                    <span class="input-icon">📍</span>
                    <input type="text" @bind="location" placeholder="Location (or 'Remote')" />
                </div>
                <button class="btn btn-primary search-btn" @onclick="SearchJobs" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="loading-spinner-small"></span>
                    }
                    else
                    {
                        <span>Search</span>
                    }
                </button>
            </div>

            <!-- Quick Filters -->
            <div class="quick-filters">
                <button class="filter-chip @(remoteOnly ? "active" : "")" @onclick="ToggleRemote">
                    🏠 Remote
                </button>
                <button class="filter-chip @(experienceLevel == "entry" ? "active" : "")" 
                        @onclick='() => SetExperience("entry")'>
                    🌱 Entry Level
                </button>
                <button class="filter-chip @(experienceLevel == "mid" ? "active" : "")" 
                        @onclick='() => SetExperience("mid")'>
                    🚀 Mid Level
                </button>
                <button class="filter-chip @(experienceLevel == "senior" ? "active" : "")" 
                        @onclick='() => SetExperience("senior")'>
                    👑 Senior
                </button>
                <button class="filter-chip @(postedWithin == "7" ? "active" : "")" 
                        @onclick='() => SetPostedWithin("7")'>
                    ⚡ Last 7 Days
                </button>
            </div>
        </div>
    </div>

    <div class="jobs-content">
        <!-- 📋 Side Filters Panel -->
        <aside class="filters-panel @(showFilters ? "open" : "")">
            <div class="filters-header">
                <h3>🎛️ Filters</h3>
                <button class="btn-ghost" @onclick="ClearFilters">Clear All</button>
            </div>

            <div class="filter-section">
                <label>⚔️ Experience Level</label>
                <div class="filter-options">
                    <label class="filter-option @(experienceLevel == "" ? "selected" : "")">
                        <input type="radio" name="exp" checked="@(experienceLevel == "")" 
                               @onchange='() => experienceLevel = ""' />
                        <span>All Levels</span>
                    </label>
                    <label class="filter-option @(experienceLevel == "entry" ? "selected" : "")">
                        <input type="radio" name="exp" checked="@(experienceLevel == "entry")" 
                               @onchange='() => experienceLevel = "entry"' />
                        <span>🌱 Entry Level</span>
                    </label>
                    <label class="filter-option @(experienceLevel == "mid" ? "selected" : "")">
                        <input type="radio" name="exp" checked="@(experienceLevel == "mid")" 
                               @onchange='() => experienceLevel = "mid"' />
                        <span>🚀 Mid Level</span>
                    </label>
                    <label class="filter-option @(experienceLevel == "senior" ? "selected" : "")">
                        <input type="radio" name="exp" checked="@(experienceLevel == "senior")" 
                               @onchange='() => experienceLevel = "senior"' />
                        <span>👑 Senior</span>
                    </label>
                    <label class="filter-option @(experienceLevel == "lead" ? "selected" : "")">
                        <input type="radio" name="exp" checked="@(experienceLevel == "lead")" 
                               @onchange='() => experienceLevel = "lead"' />
                        <span>🎖️ Lead/Principal</span>
                    </label>
                </div>
            </div>

            <div class="filter-section">
                <label>📋 Job Type</label>
                <div class="filter-options">
                    <label class="filter-option @(jobType == "" ? "selected" : "")">
                        <input type="radio" name="type" checked="@(jobType == "")" 
                               @onchange='() => jobType = ""' />
                        <span>All Types</span>
                    </label>
                    <label class="filter-option @(jobType == "fulltime" ? "selected" : "")">
                        <input type="radio" name="type" checked="@(jobType == "fulltime")" 
                               @onchange='() => jobType = "fulltime"' />
                        <span>⏰ Full-time</span>
                    </label>
                    <label class="filter-option @(jobType == "contract" ? "selected" : "")">
                        <input type="radio" name="type" checked="@(jobType == "contract")" 
                               @onchange='() => jobType = "contract"' />
                        <span>📝 Contract</span>
                    </label>
                    <label class="filter-option @(jobType == "parttime" ? "selected" : "")">
                        <input type="radio" name="type" checked="@(jobType == "parttime")" 
                               @onchange='() => jobType = "parttime"' />
                        <span>⏳ Part-time</span>
                    </label>
                </div>
            </div>

            <div class="filter-section">
                <label>📅 Posted Within</label>
                <div class="filter-options">
                    <label class="filter-option @(postedWithin == "1" ? "selected" : "")">
                        <input type="radio" name="posted" checked="@(postedWithin == "1")" 
                               @onchange='() => postedWithin = "1"' />
                        <span>🔥 Last 24 Hours</span>
                    </label>
                    <label class="filter-option @(postedWithin == "7" ? "selected" : "")">
                        <input type="radio" name="posted" checked="@(postedWithin == "7")" 
                               @onchange='() => postedWithin = "7"' />
                        <span>⚡ Last 7 Days</span>
                    </label>
                    <label class="filter-option @(postedWithin == "30" ? "selected" : "")">
                        <input type="radio" name="posted" checked="@(postedWithin == "30")" 
                               @onchange='() => postedWithin = "30"' />
                        <span>📆 Last 30 Days</span>
                    </label>
                    <label class="filter-option @(postedWithin == "" ? "selected" : "")">
                        <input type="radio" name="posted" checked="@(postedWithin == "")" 
                               @onchange='() => postedWithin = ""' />
                        <span>🌍 Any Time</span>
                    </label>
                </div>
            </div>

            <button class="btn btn-primary w-full" @onclick="SearchJobs">Apply Filters</button>
        </aside>

        <!-- 📜 Jobs List -->
        <div class="jobs-list">
            <div class="list-header">
                <button class="filter-toggle" @onclick="ToggleFilters">
                    🎛️ Filters
                </button>
                <span class="results-count">
                    @if (isLoading)
                    {
                        <span>Searching...</span>
                    }
                    else
                    {
                        <span>@jobs.Count quests found</span>
                    }
                </span>
                <select class="sort-select" @bind="sortBy">
                    <option value="relevance">🎯 Most Relevant</option>
                    <option value="date">📅 Most Recent</option>
                    <option value="match">💎 Best Match</option>
                </select>
            </div>

            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="loading-icon">🔮</div>
                    <p>Searching the realm for opportunities...</p>
                    <div class="loading-dots">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            }
            else if (jobs.Any())
            {
                <div class="jobs-grid">
                    @foreach (var job in jobs)
                    {
                        <div class="job-card @(selectedJob?.Id == job.Id ? "selected" : "")" 
                             @onclick="() => SelectJob(job)">
                            <div class="card-highlight"></div>

                            <div class="job-card-header">
                                <div class="company-avatar">
                                    <span>@job.Company[0]</span>
                                </div>
                                <div class="job-primary-info">
                                    <h3>@job.Title</h3>
                                    <p class="company-name">@job.Company</p>
                                </div>
                                @if (job.MatchScore > 0)
                                {
                                    <div class="match-badge @GetMatchClass(job.MatchScore)">
                                        <span class="match-icon">@GetMatchIcon(job.MatchScore)</span>
                                        <span>@job.MatchScore%</span>
                                    </div>
                                }
                            </div>

                            <div class="job-meta">
                                <span class="meta-item">
                                    <span class="meta-icon">📍</span>
                                    @job.Location
                                </span>
                                @if (job.IsRemote)
                                {
                                    <span class="meta-item remote">
                                        <span class="meta-icon">🏠</span>
                                        Remote
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(job.SalaryRange))
                                {
                                    <span class="meta-item salary">
                                        <span class="meta-icon">💰</span>
                                        @job.SalaryRange
                                    </span>
                                }
                            </div>

                            <div class="job-skills">
                                @foreach (var skill in job.Skills.Take(4))
                                {
                                    <span class="skill-chip">@skill</span>
                                }
                                @if (job.Skills.Count > 4)
                                {
                                    <span class="skill-chip more">+@(job.Skills.Count - 4)</span>
                                }
                            </div>

                            <div class="job-card-footer">
                                <span class="posted-time">
                                    <span>⏰</span> @GetPostedText(job.PostedDate)
                                </span>
                                <div class="card-actions">
                                    <button class="action-btn save @(job.IsSaved ? "saved" : "")" 
                                            @onclick:stopPropagation="true" 
                                            @onclick="() => SaveJob(job)"
                                            title="@(job.IsSaved ? "Saved" : "Save")">
                                        @(job.IsSaved ? "⭐" : "☆")
                                    </button>
                                    <button class="action-btn apply" 
                                            @onclick:stopPropagation="true"
                                            @onclick="() => QuickApply(job)">
                                        Apply →
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">🗺️</div>
                    <h3>No Quests Found</h3>
                    <p>Try adjusting your search or filters to discover new opportunities</p>
                    <button class="btn btn-secondary" @onclick="ClearFilters">Clear Filters</button>
                </div>
            }
        </div>

        <!-- 📖 Job Details Panel -->
        @if (selectedJob != null)
        {
            <aside class="details-panel">
                <button class="close-btn" @onclick="() => selectedJob = null">✕</button>

                <div class="details-header">
                    <div class="company-avatar large">
                        <span>@selectedJob.Company[0]</span>
                    </div>
                    <h2>@selectedJob.Title</h2>
                    <p class="company">@selectedJob.Company</p>

                    <div class="details-meta">
                        <span>📍 @selectedJob.Location</span>
                        @if (selectedJob.IsRemote)
                        {
                            <span class="remote-badge">🏠 Remote Available</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(selectedJob.SalaryRange))
                    {
                        <div class="salary-display">
                            <span class="salary-icon">💰</span>
                            <span>@selectedJob.SalaryRange</span>
                        </div>
                    }
                </div>

                <div class="details-actions">
                    <button class="btn btn-primary btn-glow" @onclick="ApplyToJob">
                        🎯 Apply Now
                    </button>
                    <button class="btn btn-secondary" @onclick="TailorResume">
                        ✨ Tailor Resume
                    </button>
                </div>

                @if (selectedJob.MatchScore > 0)
                {
                    <div class="match-section">
                        <h4>🎯 Match Analysis</h4>
                        <div class="match-circle-container">
                            <div class="match-circle @GetMatchClass(selectedJob.MatchScore)">
                                <span class="match-value">@selectedJob.MatchScore%</span>
                                <span class="match-label">Match</span>
                            </div>
                        </div>
                        <div class="match-bar-container">
                            <div class="match-bar">
                                <div class="match-fill" style="width: @(selectedJob.MatchScore)%"></div>
                            </div>
                        </div>
                    </div>
                }

                <div class="details-section">
                    <h4>📝 Description</h4>
                    <p class="description">@(selectedJob.Description ?? "No description available.")</p>
                </div>

                <div class="details-section">
                    <h4>🛠️ Required Skills</h4>
                    <div class="skills-grid">
                        @foreach (var skill in selectedJob.Skills)
                        {
                            <span class="skill-tag">@skill</span>
                        }
                    </div>
                </div>
            </aside>
        }
    </div>
</div>

@code {
    private List<JobDto> jobs = new();
    private JobDto? selectedJob;
    private string searchQuery = "";
    private string location = "";
    private bool remoteOnly;
    private string experienceLevel = "";
    private string jobType = "";
    private string postedWithin = "7";
    private string sortBy = "relevance";
    private bool isLoading;
    private bool showFilters;
    private bool isFirstRender = true;

    // ATS Modal state
    private bool showAtsModal;
    private bool isAnalyzing;
    private AtsResult? atsResult;
    private JobDto? pendingApplyJob;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isFirstRender = false;
            await SearchJobs();
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchJobs();
        }
    }

    private async Task SearchJobs()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            // Simulate API delay for better UX feel
            if (!isFirstRender)
            {
                await Task.Delay(300);
            }

            jobs = await Api.SearchJobsAsync(searchQuery, location, remoteOnly) ?? new List<JobDto>();

            // Apply client-side sorting
            jobs = sortBy switch
            {
                "date" => jobs.OrderByDescending(j => j.PostedDate).ToList(),
                "match" => jobs.OrderByDescending(j => j.MatchScore).ToList(),
                _ => jobs
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error searching jobs: {ex.Message}");
            jobs = new List<JobDto>();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ToggleRemote()
    {
        remoteOnly = !remoteOnly;
        _ = SearchJobs();
    }

    private void SetExperience(string level)
    {
        experienceLevel = experienceLevel == level ? "" : level;
    }

    private void SetPostedWithin(string days)
    {
        postedWithin = postedWithin == days ? "" : days;
    }

    private void ToggleFilters() => showFilters = !showFilters;

    private void ClearFilters()
    {
        searchQuery = "";
        location = "";
        remoteOnly = false;
        experienceLevel = "";
        jobType = "";
        postedWithin = "7";
        _ = SearchJobs();
    }

    private void SelectJob(JobDto job) => selectedJob = job;

    private async Task SaveJob(JobDto job)
    {
        job.IsSaved = !job.IsSaved;
        // Would call API to save
    }

    private async Task QuickApply(JobDto job)
    {
        selectedJob = job;
        await StartApplyFlow(job);
    }

    private async Task ApplyToJob()
    {
        if (selectedJob == null) return;
        await StartApplyFlow(selectedJob);
    }

    private async Task StartApplyFlow(JobDto job)
    {
        pendingApplyJob = job;
        showAtsModal = true;
        isAnalyzing = true;
        atsResult = null;
        StateHasChanged();

        // Simulate ATS analysis (in real app, call API)
        await Task.Delay(2000);

        // Generate mock ATS result based on job skills
        atsResult = GenerateMockAtsResult(job);
        isAnalyzing = false;
        StateHasChanged();
    }

    private AtsResult GenerateMockAtsResult(JobDto job)
    {
        // In real implementation, this would call the API to compare user's resume with job
        var random = new Random();
        var matchedCount = random.Next(3, job.Skills.Count);
        var matchedSkills = job.Skills.Take(matchedCount).ToList();
        var missingSkills = job.Skills.Skip(matchedCount).ToList();
        var score = (int)((double)matchedCount / job.Skills.Count * 100);

        var suggestions = new List<string>();
        if (score < 70)
        {
            suggestions.Add($"Add keywords like '{string.Join("', '", missingSkills.Take(2))}' to your resume");
            suggestions.Add("Quantify your achievements with specific metrics");
        }
        if (score < 50)
        {
            suggestions.Add("Consider getting certified in the required technologies");
        }

        return new AtsResult
        {
            Score = score,
            MatchedSkills = matchedSkills,
            MissingSkills = missingSkills,
            Suggestions = suggestions
        };
    }

    private void CloseAtsModal()
    {
        showAtsModal = false;
        isAnalyzing = false;
        atsResult = null;
        pendingApplyJob = null;
    }

    private void ProceedToApply()
    {
        if (pendingApplyJob != null && !string.IsNullOrEmpty(pendingApplyJob.ApplyUrl))
        {
            // Open the job application URL in a new tab
            Navigation.NavigateTo(pendingApplyJob.ApplyUrl, forceLoad: true);
        }
        CloseAtsModal();
    }

    private void GoToTailorResume()
    {
        CloseAtsModal();
        Navigation.NavigateTo("/resumes");
    }

    private void GoToUploadResume()
    {
        CloseAtsModal();
        Navigation.NavigateTo("/resumes");
    }

    private string GetAtsScoreClass(int score) => score >= 80 ? "excellent" : score >= 60 ? "good" : score >= 40 ? "fair" : "poor";

    private string GetAtsScoreTitle(int score) => score switch
    {
        >= 90 => "Excellent Match! 🎉",
        >= 70 => "Good Match! ✨",
        >= 50 => "Moderate Match",
        _ => "Low Match ⚠️"
    };

    private string GetAtsScoreDescription(int score) => score switch
    {
        >= 90 => "Your resume is an excellent fit for this position.",
        >= 70 => "Your resume matches most of the job requirements.",
        >= 50 => "Consider adding missing keywords to improve your chances.",
        _ => "Your resume may need significant improvements for this role."
    };

    private async Task TailorResume()
    {
        if (selectedJob == null) return;
        Navigation.NavigateTo("/resumes");
    }

    private string GetMatchClass(int score) => score >= 80 ? "high" : score >= 60 ? "medium" : "low";

    private string GetMatchIcon(int score) => score >= 80 ? "🔥" : score >= 60 ? "✨" : "💫";

    private string GetPostedText(DateTime date)
    {
        var days = (DateTime.Now - date).Days;
        return days == 0 ? "Today" : days == 1 ? "Yesterday" : $"{days}d ago";
    }

    // ATS Result model
    private class AtsResult
    {
        public int Score { get; set; }
        public List<string> MatchedSkills { get; set; } = new();
        public List<string> MissingSkills { get; set; } = new();
        public List<string> Suggestions { get; set; } = new();
    }
}

<style>
    .jobs-page {
        max-width: 1600px;
        margin: 0 auto;
    }

    /* Quest Header */
    .quest-header {
        text-align: center;
        padding: 2rem;
        margin-bottom: 1rem;
    }

    .header-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: rgba(139, 92, 246, 0.15);
        border: 1px solid rgba(139, 92, 246, 0.3);
        border-radius: 50px;
        font-size: 0.875rem;
        color: var(--primary);
        margin-bottom: 1rem;
    }

    .quest-header h1 {
        font-size: 2.5rem;
        color: white;
        margin-bottom: 0.5rem;
    }

    .quest-header p {
        color: var(--text-secondary);
    }

    /* Search Section */
    .search-section {
        padding: 0 1rem 1.5rem;
    }

    .search-container {
        background: rgba(20, 20, 40, 0.6);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
    }

    .search-main {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .search-input-group {
        flex: 1;
        min-width: 200px;
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1rem;
    }

    .search-input-group input {
        width: 100%;
        padding: 0.875rem 1rem 0.875rem 3rem;
        border-radius: 12px;
        background: var(--bg-input);
        border: 1px solid var(--border);
        color: var(--text-primary);
        font-size: 0.95rem;
        transition: all 0.3s;
    }

    .search-input-group input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
    }

    .search-btn {
        padding: 0.875rem 2rem;
        min-width: 120px;
    }

    .loading-spinner-small {
