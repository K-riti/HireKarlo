@page "/login"
@inject ApiClient Api
@inject AuthStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Login - HireKarlo</PageTitle>

<div class="login-page">
    <div class="login-container">
        <div class="login-header">
            <h1>🚀 Welcome to HireKarlo</h1>
            <p>Your AI-powered career toolkit</p>
        </div>

        <div class="social-login">
            <button class="btn-social google" @onclick="LoginWithGoogle">
                <span class="icon">G</span>
                <span>Continue with Google</span>
            </button>
            <button class="btn-social linkedin" @onclick="LoginWithLinkedIn">
                <span class="icon">in</span>
                <span>Continue with LinkedIn</span>
            </button>
        </div>

        <div class="divider">
            <span>or</span>
        </div>

        <form class="login-form" @onsubmit="HandleLogin">
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="email" placeholder="you@example.com" required />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="password" placeholder="••••••••" required />
            </div>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }
            <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                @(isLoading ? "Signing in..." : "Sign In")
            </button>
        </form>

        <div class="login-footer">
            <p>Don't have an account? <a href="/register">Sign up free</a></p>
            <a href="/forgot-password">Forgot password?</a>
        </div>

        <div class="features-preview">
            <h3>What you'll get:</h3>
            <ul>
                <li>🎯 AI-powered resume optimization</li>
                <li>📊 ATS score analysis</li>
                <li>🎤 Mock interview practice</li>
                <li>📚 Personalized learning paths</li>
                <li>💼 Smart job matching</li>
            </ul>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = "";

        var result = await Api.LoginAsync(email, password);
        if (result != null && !string.IsNullOrEmpty(result.Token))
        {
            await AuthState.LoginAsync(result.Token, new UserInfo
            {
                Id = result.UserId,
                Email = result.Email,
                Name = result.Name
            });
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = "Invalid email or password";
        }

        isLoading = false;
    }

    private void LoginWithGoogle()
    {
        // Redirect to Google OAuth endpoint
        Navigation.NavigateTo("/auth/google", forceLoad: true);
    }

    private void LoginWithLinkedIn()
    {
        // Redirect to LinkedIn OAuth endpoint
        Navigation.NavigateTo("/auth/linkedin", forceLoad: true);
    }
}
