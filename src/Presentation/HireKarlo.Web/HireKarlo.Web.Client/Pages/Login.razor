@page "/login"
@rendermode InteractiveAuto
@inject ApiClient Api
@inject AuthStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Login - HireKarlo</PageTitle>

<div class="login-page">
    <div class="login-container">
        <div class="login-header">
            <h1>🚀 Welcome to HireKarlo</h1>
            <p>Your AI-powered career toolkit</p>
        </div>

        <div class="social-login">
            @* Use anchor tags for OAuth - they work immediately without waiting for WASM *@
            <a href="/auth/google" class="btn-social google">
                <span class="icon">G</span>
                <span>Continue with Google</span>
            </a>
            <a href="/auth/linkedin" class="btn-social linkedin">
                <span class="icon">in</span>
                <span>Continue with LinkedIn</span>
            </a>
        </div>

        <div class="divider">
            <span>or</span>
        </div>

        <form class="login-form" @onsubmit="HandleLogin" @onsubmit:preventDefault>
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="email" placeholder="you@example.com" required />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="password" placeholder="••••••••" required />
            </div>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }
            <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner"></span>
                    <span>Signing in...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </button>
        </form>

        <div class="login-footer">
            <p>Don't have an account? <a href="/register">Sign up free</a></p>
            <a href="/forgot-password">Forgot password?</a>
        </div>

        <div class="features-preview">
            <h3>What you'll get:</h3>
            <ul>
                <li>🎯 AI-powered resume optimization</li>
                <li>📊 ATS score analysis</li>
                <li>🎤 Mock interview practice</li>
                <li>📚 Personalized learning paths</li>
                <li>💼 Smart job matching</li>
            </ul>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = "";

        try
        {
            var result = await Api.LoginAsync(email, password);
            var token = result?.Token ?? result?.AccessToken;
            if (result != null && result.Success && !string.IsNullOrEmpty(token))
            {
                await AuthState.LoginAsync(token, new UserInfo
                {
                    Id = result.UserId != Guid.Empty ? result.UserId : Guid.NewGuid(),
                    Email = result.Email ?? email,
                    Name = result.Name ?? ""
                });
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = result?.Error ?? "Invalid email or password";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Unable to connect to server. Please try again.";
            Console.WriteLine($"Login error: {ex.Message}");
        }

        isLoading = false;
    }
}
