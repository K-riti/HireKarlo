@page "/dashboard"
@rendermode InteractiveAuto
@inject ApiClient Api
@inject AuthStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Dashboard - HireKarlo</PageTitle>

<div class="dashboard-page">
    @if (!isLoaded)
    {
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>Loading your dashboard...</p>
        </div>
    }
    else if (!AuthState.IsAuthenticated)
    {
        <div class="auth-required">
            <h2>🔐 Please Sign In</h2>
            <p>You need to be logged in to view your dashboard.</p>
            <a href="/login" class="btn btn-primary">Sign In</a>
        </div>
    }
    else
    {
        <div class="dashboard-header">
            <h1>👋 Welcome back, @(AuthState.CurrentUser?.Name ?? "there")!</h1>
            <p>Here's your career progress at a glance</p>
        </div>

        <div class="quick-stats">
            <div class="stat-card">
                <span class="stat-icon">📄</span>
                <div class="stat-info">
                    <span class="stat-value">@resumeCount</span>
                    <span class="stat-label">Resumes</span>
                </div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">💼</span>
                <div class="stat-info">
                    <span class="stat-value">@applicationCount</span>
                    <span class="stat-label">Applications</span>
                </div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">🎤</span>
                <div class="stat-info">
                    <span class="stat-value">@interviewCount</span>
                    <span class="stat-label">Mock Interviews</span>
                </div>
            </div>
            <div class="stat-card">
                <span class="stat-icon">📈</span>
                <div class="stat-info">
                    <span class="stat-value">@learningProgress%</span>
                    <span class="stat-label">Learning Progress</span>
                </div>
            </div>
        </div>

        <div class="quick-actions">
            <h2>Quick Actions</h2>
            <div class="actions-grid">
                <a href="/resumes" class="action-card">
                    <span class="action-icon">📄</span>
                    <h3>Upload Resume</h3>
                    <p>Get your resume analyzed by AI</p>
                </a>
                <a href="/jobs" class="action-card">
                    <span class="action-icon">🔍</span>
                    <h3>Find Jobs</h3>
                    <p>Discover matched opportunities</p>
                </a>
                <a href="/mock-interview" class="action-card">
                    <span class="action-icon">🎤</span>
                    <h3>Practice Interview</h3>
                    <p>AI-powered mock interviews</p>
                </a>
                <a href="/learning" class="action-card">
                    <span class="action-icon">📚</span>
                    <h3>Learn Skills</h3>
                    <p>Personalized learning paths</p>
                </a>
            </div>
        </div>
    }
</div>

<style>
    .dashboard-page {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .loading-state, .auth-required {
        text-align: center;
        padding: 4rem 2rem;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 4px solid rgba(99, 102, 241, 0.3);
        border-top-color: #6366f1;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 1rem;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .dashboard-header {
        margin-bottom: 2rem;
    }

    .dashboard-header h1 {
        font-size: 1.75rem;
        color: white;
        margin-bottom: 0.5rem;
    }

    .dashboard-header p {
        color: rgba(255, 255, 255, 0.7);
    }

    .quick-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .stat-icon {
        font-size: 2rem;
    }

    .stat-info {
        display: flex;
        flex-direction: column;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: white;
    }

    .stat-label {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.6);
    }

    .quick-actions h2 {
        color: white;
        margin-bottom: 1rem;
    }

    .actions-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
    }

    .action-card {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 1.5rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: block;
    }

    .action-card:hover {
        background: rgba(99, 102, 241, 0.2);
        transform: translateY(-2px);
    }

    .action-icon {
        font-size: 2rem;
        display: block;
        margin-bottom: 0.75rem;
    }

    .action-card h3 {
        color: white;
        font-size: 1rem;
        margin-bottom: 0.25rem;
    }

    .action-card p {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.875rem;
        margin: 0;
    }

    .auth-required h2 {
        color: white;
        margin-bottom: 1rem;
    }

    .auth-required p {
        color: rgba(255, 255, 255, 0.7);
        margin-bottom: 1.5rem;
    }

    .btn-primary {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
    }
</style>

@code {
    private bool isLoaded = false;
    private int resumeCount = 0;
    private int applicationCount = 0;
    private int interviewCount = 0;
    private int learningProgress = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthState.InitializeAsync();
            isLoaded = true;
            StateHasChanged();

            if (AuthState.IsAuthenticated)
            {
                await LoadDashboardData();
            }
        }
    }

    private async Task LoadDashboardData()
    {
        try
        {
            var dashboard = await Api.GetDashboardAsync();
            if (dashboard != null)
            {
                applicationCount = dashboard.TotalApplications;
                interviewCount = dashboard.Interviews;
                learningProgress = dashboard.LearningProgress;
                resumeCount = dashboard.ActiveJobs;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
    }
}
