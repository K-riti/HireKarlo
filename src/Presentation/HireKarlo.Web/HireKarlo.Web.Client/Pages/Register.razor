@page "/register"
@rendermode InteractiveWebAssembly
@inject ApiClient Api
@inject AuthStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Sign Up - HireKarlo</PageTitle>

<div class="register-page">
    <div class="register-container">
        <div class="register-header">
            <h1>🚀 Create Your Account</h1>
            <p>Start your AI-powered career journey</p>
        </div>

        <div class="social-login">
            <button class="btn-social google" @onclick="RegisterWithGoogle">
                <span class="icon">G</span>
                <span>Sign up with Google</span>
            </button>
            <button class="btn-social linkedin" @onclick="RegisterWithLinkedIn">
                <span class="icon">in</span>
                <span>Sign up with LinkedIn</span>
            </button>
        </div>

        <div class="divider">
            <span>or</span>
        </div>

        <form class="register-form" @onsubmit="HandleRegister">
            <div class="form-row">
                <div class="form-group">
                    <label>First Name</label>
                    <input type="text" @bind="firstName" placeholder="John" required />
                </div>
                <div class="form-group">
                    <label>Last Name</label>
                    <input type="text" @bind="lastName" placeholder="Doe" required />
                </div>
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="email" placeholder="you@example.com" required />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="password" placeholder="Min. 8 characters" required minlength="8" />
            </div>
            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password" @bind="confirmPassword" placeholder="Re-enter password" required />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-message">@successMessage</div>
            }

            <label class="checkbox-label">
                <input type="checkbox" @bind="agreeToTerms" required />
                <span>I agree to the <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a></span>
            </label>

            <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
                @(isLoading ? "Creating account..." : "Create Account")
            </button>
        </form>

        <div class="register-footer">
            <p>Already have an account? <a href="/login">Sign in</a></p>
        </div>

        <div class="features-preview">
            <h3>What you'll unlock:</h3>
            <div class="feature-list">
                <div class="feature-item">
                    <span class="feature-icon">🎯</span>
                    <span>AI Resume Optimization</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">🎤</span>
                    <span>Mock Interview Practice</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">📊</span>
                    <span>ATS Score Analysis</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">📚</span>
                    <span>Personalized Learning</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string firstName = "";
    private string lastName = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private bool agreeToTerms = false;
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    private async Task HandleRegister()
    {
        errorMessage = "";
        successMessage = "";

        if (password != confirmPassword)
        {
            errorMessage = "Passwords do not match";
            return;
        }

        if (!agreeToTerms)
        {
            errorMessage = "Please agree to the Terms of Service";
            return;
        }

        isLoading = true;

        try
        {
            var result = await Api.RegisterAsync(email, firstName, lastName, password);
            var token = result?.Token ?? result?.AccessToken;
            if (result != null && result.Success && !string.IsNullOrEmpty(token))
            {
                await AuthState.LoginAsync(token, new UserInfo
                {
                    Id = result.UserId != Guid.Empty ? result.UserId : Guid.NewGuid(),
                    Email = result.Email ?? email,
                    Name = result.Name ?? $"{firstName} {lastName}"
                });
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = result?.Error ?? "Registration failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred. Please try again.";
            Console.WriteLine($"Registration error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void RegisterWithGoogle()
    {
        // Redirect to Google OAuth endpoint (same as login - will create account if needed)
        Navigation.NavigateTo("/auth/google", forceLoad: true);
    }

    private void RegisterWithLinkedIn()
    {
        // Redirect to LinkedIn OAuth endpoint (same as login - will create account if needed)
        Navigation.NavigateTo("/auth/linkedin", forceLoad: true);
    }
}
